// Load data and initialize page
async function loadData() {
    try {
        const response = await fetch('data.json');
        const data = await response.json();
        
        renderPublications(data.publications);
        renderGrants(data.grants);
        renderTeaching(data.teaching);
        renderCareer(data.career);
        
        // Re-observe fade-in elements after rendering
        initFadeIn();
    } catch (error) {
        console.error('Error loading data:', error);
    }
}

// Render publications grouped by year
function renderPublications(publications) {
    const container = document.getElementById('publications-container');
    
    // Group by year
    const groupedByYear = publications.reduce((acc, pub) => {
        if (!acc[pub.year]) acc[pub.year] = [];
        acc[pub.year].push(pub);
        return acc;
    }, {});
    
    // Sort years descending
    const years = Object.keys(groupedByYear).sort((a, b) => b - a);
    
    let html = '';
    years.forEach(year => {
        html += `
            <div class="pub-year-group fade-in">
                <h3 class="pub-year">${year}</h3>
                <div class="pub-list">
                    ${groupedByYear[year].map(pub => renderPublication(pub)).join('')}
                </div>
            </div>
        `;
    });
    
    container.innerHTML = html;
}

// Render individual publication
function renderPublication(pub) {
    const badges = [];
    
    if (pub.metrics?.bestPaper) {
        badges.push('<span class="pub-badge badge-award">🏆 Best Paper Award</span>');
    }
    
    if (pub.metrics?.impactFactor) {
        badges.push(`<span class="pub-badge badge-if">IF ${pub.metrics.impactFactor.toFixed(1)}</span>`);
    }
    
    if (pub.metrics?.quartile) {
        const qClass = `badge-${pub.metrics.quartile.toLowerCase()}`;
        badges.push(`<span class="pub-badge ${qClass}">${pub.metrics.quartile}</span>`);
    }
    
    if (pub.metrics?.citations && pub.metrics.citations > 50) {
        badges.push(`<span class="pub-badge badge-citations">📊 ${pub.metrics.citations} citations</span>`);
    }
    
    if (pub.doi) {
        badges.push(`<a href="https://doi.org/${pub.doi}" target="_blank" class="pub-link">DOI <span class="icon-external"></span></a>`);
    }
    
    return `
        <div class="pub-item">
            <div class="pub-venue">${pub.venue}</div>
            <div class="pub-title">${pub.title}</div>
            <div class="pub-authors">${pub.authors}</div>
            <div class="pub-badges">
                ${badges.join('')}
            </div>
        </div>
    `;
}

// Render grants
function renderGrants(grants) {
    const container = document.getElementById('grants-container');
    
    const html = grants.map(grant => `
        <div class="grant-item fade-in">
            <span class="grant-year">${grant.year}</span>
            <span class="grant-amount">${grant.amount}</span>
            <span class="grant-project">${grant.project}</span>
            <span class="grant-source">${grant.source}</span>
        </div>
    `).join('');
    
    container.innerHTML = html;
}

// Render teaching
function renderTeaching(courses) {
    const container = document.getElementById('teaching-container');
    
    const html = courses.map(course => `
        <div class="teaching-card fade-in">
            <h3>${course.title}</h3>
            <div class="teaching-meta">${course.meta}</div>
            <div class="teaching-highlight">${course.highlight}</div>
        </div>
    `).join('');
    
    container.innerHTML = html;
}

// Render career timeline
function renderCareer(positions) {
    const container = document.getElementById('career-container');
    
    const html = positions.map(pos => `
        <div class="timeline-item ${pos.current ? '' : 'past'} fade-in">
            <div class="timeline-year">${pos.year}</div>
            <div class="timeline-role">${pos.role}</div>
            <div class="timeline-org">${pos.org}</div>
            <div class="timeline-desc">${pos.desc}</div>
        </div>
    `).join('');
    
    container.innerHTML = html;
}

// Initialize fade-in animations
function initFadeIn() {
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, observerOptions);

    document.querySelectorAll('.fade-in').forEach(el => {
        observer.observe(el);
    });
}

// Nav scroll effect
function initNav() {
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
            nav.classList.add('scrolled');
        } else {
            nav.classList.remove('scrolled');
        }
    });
}

// Mobile menu toggle
function initMobileMenu() {
    const hamburger = document.getElementById('hamburger');
    const navLinks = document.getElementById('navLinks');
    
    hamburger.addEventListener('click', () => {
        navLinks.classList.toggle('open');
    });

    // Close mobile menu when clicking a link
    navLinks.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
            navLinks.classList.remove('open');
        });
    });
}

// Initialize everything when DOM is ready
document.addEventListener('DOMContentLoaded', () => {
    loadData();
    initNav();
    initMobileMenu();
    initFadeIn(); // For static content
});
